# =========================================================================
# MoneyUp - Environment Variables Template
# =========================================================================

# App Environment
NODE_ENV=development

# Gateway HTTP Service
PORT=3000

# AI Microservice (TCP)
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=3001

# Scraper Microservice (TCP)
SCRAPER_SERVICE_HOST=127.0.0.1
SCRAPER_SERVICE_PORT=3002

# Auth Microservice (TCP)
AUTH_SERVICE_HOST=127.0.0.1
AUTH_SERVICE_PORT=3003

# JWT Secret (for Auth Service)
JWT_SECRET=super_secret_jwt_key_please_change_in_production
JWT_EXPIRES_IN=1d
