# =========================================================================
# MoneyUp - Environment Variables Template
# =========================================================================

# App Environment
NODE_ENV=development

# Gateway HTTP Port
PORT=3000

# JWT Secret (for Auth Service)
JWT_SECRET=developmentsupersecretkeyforlocaltestingonly12345
JWT_EXPIRES_IN=1d

# Enable Debug AI Conversation Panel Controls on Dashboard
VITE_DEBUG_AI_CHAT=true

# Scraper Operation Mode (live | simulation
SCRAPER_MODE=live # Live / Simulated scraper.
SCRAPER_DEBUG=0 # Debug mode toggle.
SCRAPER_LOGIN_TIMEOUT_MS=6000 # Max Login screen timeout.
SCRAPER_DEFAULT_TIMEOUT_MS=10000 # Max Data screens timeout.