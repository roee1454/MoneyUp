{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MoneyUp",
  "version": "0.1.0",
  "identifier": "com.eviltwin.MoneyUp",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "node ../../scripts/prepare-desktop.js",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MoneyUp",
        "width": 1368,
        "height": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "msi", "app"],
    "resources": ["../resources/bin/**/*", "../resources/server/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
