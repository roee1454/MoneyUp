{
  "name": "money-up",
  "version": "1.0.0",
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "packages:build": "turbo run build --filter=@money-up/types --filter=@money-up/common",
    "server:build": "turbo run build --filter=server",
    "client:build": "turbo run build --filter=web",
    "build": "turbo run build",
    "desktop:dev": "pnpm --dir apps/desktop tauri dev",
    "desktop:build": "pnpm --dir apps/desktop tauri build",
    "server:dev": "turbo run dev --filter=server",
    "client:dev": "turbo run dev --filter=web",
    "dev": "turbo run dev",
    "server:start": "node apps/server/dist/main",
    "client:start": "pnpm --dir apps/web preview",
    "start": "node apps/server/dist/main",
    "start:dev": "turbo run dev --filter=server",
    "start:debug": "pnpm --dir apps/server start:debug",
    "start:prod": "node apps/server/dist/main",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "js-tiktoken": "^1.0.21",
    "@money-up/common": "workspace:*"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
