{
  "name": "money-up",
  "version": "0.0.1",
  "packageManager": "pnpm@10.24.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build:packages": "pnpm --dir packages/types build && pnpm --dir packages/common build",
    "build:apps": "nest build --all",
    "build": "pnpm build:packages && pnpm build:apps",
    "build:web": "pnpm --dir clients/web build",
    "dev:apps": "concurrently -c \"cyan,magenta,yellow,blue,green\" \"nest start --watch --exec 'node --max-old-space-size=192' ai-service\" \"nest start --watch --exec 'node --max-old-space-size=192' auth-service\" \"nest start --watch --exec 'node --max-old-space-size=192' scraper-service\" \"nest start --watch --exec 'node --max-old-space-size=192' users-service\" \"nest start --watch --exec 'node --max-old-space-size=192' gateway\"",
    "dev:web": "pnpm --dir clients/web dev",
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"bgBlue,bgMagenta\" \"pnpm dev:services\" \"pnpm dev:web\"",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/gateway/main",
    "start:apps": "concurrently -c \"cyan,magenta,yellow,blue,green\" \"node dist/apps/ai/main\" \"node dist/apps/auth/main\" \"node dist/apps/scraper/main\" \"node dist/apps/users/main\" \"node dist/apps/gateway/main\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/gateway/test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.21",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.22",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.22",
    "@puppeteer/browsers": "3.0.3",
    "better-sqlite3": "^12.10.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "israeli-bank-scrapers": "file:./libs/israeli-bank-scrapers-patched.tgz",
    "puppeteer": "24.43.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.29",
    "zod": "^4.4.3",
    "@money-up/common": "workspace:*",
    "@money-up/types": "workspace:*"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
